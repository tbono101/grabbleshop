# ─── AI ────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Payments ──────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...

# ─── Sales Tax ─────────────────────────────────────────────────────────────────
TAXJAR_API_KEY=...

# ─── Shipping ──────────────────────────────────────────────────────────────────
EASYPOST_API_KEY=...

# ─── Email ─────────────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...

# ─── SMS / Voice ───────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...

# ─── CDN / Media ───────────────────────────────────────────────────────────────
CLOUDFLARE_API_KEY=...

# ─── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string

# ─── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=./data/grabbleshop.sqlite

# ─── Webhooks ──────────────────────────────────────────────────────────────────
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Shipping origin (used for EasyPost / TaxJar from-address) ─────────────────
PLATFORM_NAME=GrabbleShop
PLATFORM_STREET=1 Disney Way
PLATFORM_CITY=Orlando
PLATFORM_STATE=FL
PLATFORM_ZIP=32830

# ─── CORS (comma-separated allowed origins) ────────────────────────────────────
CLIENT_ORIGIN=https://grabbleshop-production.up.railway.app

# ─── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# ─── Frontend (only needed for local dev — production uses /api on same origin) ─
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...
